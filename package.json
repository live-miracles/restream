{
    "name": "restream",
    "version": "1.0.0",
    "description": "A streaming server which takes inputs and replicates them to multiple outputs.",
    "main": "dist/index.js",
    "scripts": {
        "start": "node dist/index.js",
        "dev": "npx tsx watch --ignore 'test/artifacts/**' --ignore 'public/**' src/index.ts",
        "build": "npm run build:backend && npm run build:frontend",
        "build:backend": "npx tsc -p tsconfig.backend.json",
        "build:frontend": "npx tsc -p tsconfig.json",
        "watch:backend": "npx tsc -p tsconfig.backend.json --watch",
        "watch:frontend": "npx tsc -p tsconfig.json --watch",
        "ts-build": "npm run build:frontend",
        "ts-watch": "npm run watch:frontend",
        "css": "npx tailwindcss -i public/input.css -o public/output.css",
        "css-watch": "npx tailwindcss -i public/input.css -o public/output.css --watch",
        "format": "npx prettier --write .",
        "format:check": "npx prettier --check .",
        "test": "echo \"Error: no test specified\" && exit 1",
        "test:routes": "node --require tsx/cjs --test test/routes/*.test.js",
        "test:normalization": "node --test test/artifacts/run-2x3-normalization.test.mjs",
        "test:integration": "node test/artifacts/run-2x3.mjs"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "engines": {
        "node": ">=20.19.0 <26",
        "npm": ">=10"
    },
    "dependencies": {
        "better-sqlite3": "12.6.0",
        "compression": "^1.8.1",
        "express": "5.1.0",
        "hls.js": "^1.5.20"
    },
    "devDependencies": {
        "@tailwindcss/cli": "4.1.18",
        "@types/better-sqlite3": "^7.6.13",
        "@types/compression": "^1.8.1",
        "@types/node": "^25.7.0",
        "daisyui": "5.5.14",
        "nodemon": "3.1.11",
        "prettier": "3.7.4",
        "prettier-plugin-tailwindcss": "0.7.2",
        "supertest": "^7.2.2",
        "tailwindcss": "4.1.18",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
}
