{
    "name": "restream",
    "version": "1.0.0",
    "description": "A streaming server which takes inputs and replicates them to multiple outputs.",
    "main": "src/index.js",
    "scripts": {
        "start": "node src/index.js",
        "dev": "npx nodemon --ignore 'test/artifacts/**' src/index.js",
        "css": "npx tailwindcss -i input.css -o public/output.css",
        "css-watch": "npx tailwindcss -i input.css -o public/output.css --watch",
        "format": "npx prettier --write .",
        "test": "npm run test:smoke && npm run test:unit",
        "test:routes": "node --test test/routes/*.test.js",
        "test:unit": "npm run test:frontend && npm run test:services",
        "test:smoke": "npm run test:routes",
        "test:frontend": "node --disable-warning=ExperimentalWarning --experimental-vm-modules --test test/frontend/*.test.mjs",
        "test:services": "node --test test/services/*.test.js",
        "test:4x3": "node test/artifacts/run-4x3.mjs"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "engines": {
        "node": ">=20.19.0 <26",
        "npm": ">=10"
    },
    "dependencies": {
        "better-sqlite3": "12.6.0",
        "compression": "^1.8.1",
        "express": "5.1.0",
        "hls.js": "^1.5.20"
    },
    "devDependencies": {
        "@tailwindcss/cli": "4.1.18",
        "daisyui": "5.5.14",
        "jsdom": "^26.1.0",
        "nodemon": "3.1.11",
        "prettier": "3.7.4",
        "prettier-plugin-tailwindcss": "0.7.2",
        "supertest": "^7.2.2",
        "tailwindcss": "4.1.18"
    }
}
