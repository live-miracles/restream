{
  "scripts": {
    "build:frontend": "npx tsc -p tsconfig.json && npx tailwindcss -i public/input.css -o public/output.css",
    "build:css": "npx tailwindcss -i public/input.css -o public/output.css",
    "format:frontend": "npx prettier --write \"public/ts/**/*.ts\" \"public/*.html\" public/input.css",
    "format:frontend:check": "npx prettier --check \"public/ts/**/*.ts\" \"public/*.html\" public/input.css",
    "format:check": "npx tsc -p tsconfig.json --noEmit",
    "hooks:install": "./scripts/install-git-hooks.sh",
    "test:e2e": "npx playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/cli": "^4.3.1",
    "daisyui": "^5.6.3",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "hls.js": "^1.6.16"
  }
}
