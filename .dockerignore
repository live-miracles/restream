# Build artifacts — excluded to keep context small; Docker stages regenerate them
target/
.build/
*.build-lock

# Runtime data — never bake into the image
data.db
media/
logs/

# public/bin/ffmpeg is generated by native-deps stage and copied explicitly;
# exclude the rest of public/bin to avoid stale host copies overwriting it.
public/bin/

# Source control and CI config
.git/
.github/
.claude/

# Docs, legacy, ops
docs/
old/
patches/
monitoring/
deploy/

# Node artefacts
node_modules/
public/js/
