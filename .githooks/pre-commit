#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=ACMR)

if ((${#staged_files[@]} == 0)); then
    exit 0
fi

rust_files=()
frontend_files=()
stashed=0
stash_label="pre-commit-$(date +%s)-$$"
overlap_files=()

mapfile -t unstaged_files < <(git diff --name-only --diff-filter=ACMR)

declare -A unstaged_lookup=()
for file in "${unstaged_files[@]}"; do
    unstaged_lookup["$file"]=1
done

for file in "${staged_files[@]}"; do
    if [[ -n "${unstaged_lookup[$file]+x}" ]]; then
        overlap_files+=("$file")
    fi
done

stash_unstaged() {
    if ((${#overlap_files[@]} == 0)); then
        return 0
    fi

    local before_ref
    local after_ref
    before_ref="$(git rev-parse -q --verify refs/stash || true)"

    if ! git stash push --keep-index -q -m "$stash_label" -- "${overlap_files[@]}"; then
        echo "pre-commit: failed to stash unstaged changes in staged files; aborting"
        return 1
    fi

    after_ref="$(git rev-parse -q --verify refs/stash || true)"
    if [[ "$before_ref" != "$after_ref" ]]; then
        stashed=1
    fi
}

restore_unstaged() {
    if ((stashed == 1)); then
        if ! git stash pop -q; then
            echo "pre-commit: failed to restore unstaged changes; recover with: git stash list && git stash pop"
            exit 1
        fi
    fi
}

if ! git diff --quiet; then
    stash_unstaged
fi

trap restore_unstaged EXIT

for file in "${staged_files[@]}"; do
    if [[ "$file" == *.rs ]]; then
        rust_files+=("$file")
        continue
    fi

    if [[ "$file" =~ ^public/ts/.*\.ts$ ]] ||
        [[ "$file" =~ ^public/.*\.html$ ]] ||
        [[ "$file" == "public/input.css" ]]; then
        frontend_files+=("$file")
    fi
done

if ((${#rust_files[@]} > 0)); then
    echo "pre-commit: formatting staged Rust files"
    rustfmt --edition 2024 "${rust_files[@]}"
    git add -- "${rust_files[@]}"
fi

if ((${#frontend_files[@]} > 0)); then
    echo "pre-commit: formatting staged frontend files"
    npx --no-install prettier --write "${frontend_files[@]}"
    git add -- "${frontend_files[@]}"
fi

trap - EXIT
restore_unstaged
