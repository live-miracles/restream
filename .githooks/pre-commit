#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

mapfile -t staged_files < <(git diff --cached --name-only --diff-filter=ACMR)

if ((${#staged_files[@]} == 0)); then
    exit 0
fi

rust_files=()
frontend_files=()

for file in "${staged_files[@]}"; do
    if [[ "$file" == *.rs ]]; then
        rust_files+=("$file")
        continue
    fi

    if [[ "$file" =~ ^public/ts/.*\.ts$ ]] ||
        [[ "$file" =~ ^public/.*\.html$ ]] ||
        [[ "$file" == "public/input.css" ]]; then
        frontend_files+=("$file")
    fi
done

if ((${#rust_files[@]} > 0)); then
    echo "pre-commit: checking staged Rust formatting"
    if ! rustfmt --edition 2024 --check "${rust_files[@]}"; then
        echo "pre-commit: Rust formatting check failed; run rustfmt --edition 2024 on staged .rs files"
        exit 1
    fi
fi

if ((${#frontend_files[@]} > 0)); then
    echo "pre-commit: checking staged frontend formatting"
    if ! npx --no-install prettier --check "${frontend_files[@]}"; then
        echo "pre-commit: frontend formatting check failed; run prettier --write on staged frontend files"
        exit 1
    fi
fi
