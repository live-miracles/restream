From: Live Miracles <noreply@livemiracles.com>
Date: Fri, 22 May 2026 21:05:00 +0530
Subject: [PATCH] feat(srt): Add global srtLatency parameter to MediaMTX

This patch adds a global 'srtLatency' configuration option to mediamtx.yml.
This parameter configures both the receiver latency and peer latency of the 
global SRT listener without requiring any unsafe reflection or third-party library forks.

---
diff --git a/internal/conf/conf.go b/internal/conf/conf.go
index 1188972f..f664ea6e 100644
--- a/internal/conf/conf.go
+++ b/internal/conf/conf.go
@@ -391,8 +391,9 @@ type Conf struct {
 	WebRTCICEServers            *[]string         `json:"webrtcICEServers,omitempty" deprecated:"true"`
 
 	// SRT server
-	SRT        bool   `json:"srt"`
-	SRTAddress string `json:"srtAddress"`
+	SRT        bool     `json:"srt"`
+	SRTAddress string   `json:"srtAddress"`
+	SRTLatency Duration `json:"srtLatency"`
 
 	// Record (deprecated)
 	Record                *bool         `json:"record,omitempty" deprecated:"true"`
@@ -522,6 +523,7 @@ func (conf *Conf) setDefaults() {
 	// SRT server
 	conf.SRT = true
 	conf.SRTAddress = ":8890"
+	conf.SRTLatency = 120 * Duration(time.Millisecond)
 
 	conf.PathDefaults.setDefaults()
 }
diff --git a/internal/core/core.go b/internal/core/core.go
index 58234642..ef215c45 100644
--- a/internal/core/core.go
+++ b/internal/core/core.go
@@ -662,6 +662,7 @@ func (p *Core) createResources(initial bool) error {
 			ReadTimeout:         p.conf.ReadTimeout,
 			WriteTimeout:        p.conf.WriteTimeout,
 			UDPMaxPayloadSize:   p.conf.UDPMaxPayloadSize,
+			SRTLatency:          p.conf.SRTLatency,
 			RunOnConnect:        p.conf.RunOnConnect,
 			RunOnConnectRestart: p.conf.RunOnConnectRestart,
 			RunOnDisconnect:     p.conf.RunOnDisconnect,
diff --git a/internal/servers/srt/server.go b/internal/servers/srt/server.go
index f69a0ad0..ee6532f9 100644
--- a/internal/servers/srt/server.go
+++ b/internal/servers/srt/server.go
@@ -79,6 +79,7 @@ type Server struct {
 	ReadTimeout         conf.Duration
 	WriteTimeout        conf.Duration
 	UDPMaxPayloadSize   int
+	SRTLatency          conf.Duration
 	RunOnConnect        string
 	RunOnConnectRestart bool
 	RunOnDisconnect     string
@@ -108,6 +109,10 @@ func (s *Server) Initialize() error {
 	conf.ConnectionTimeout = time.Duration(s.ReadTimeout)
 	conf.PeerIdleTimeout = time.Duration(s.ReadTimeout)
 	conf.PayloadSize = uint32(srtMaxPayloadSize(s.UDPMaxPayloadSize))
+	if s.SRTLatency > 0 {
+		conf.ReceiverLatency = time.Duration(s.SRTLatency)
+		conf.PeerLatency = time.Duration(s.SRTLatency)
+	}
 
 	var err error
 	s.ln, err = srt.Listen("srt", s.Address, conf)
diff --git a/mediamtx.yml b/mediamtx.yml
index 47f04b62..999aecee 100644
--- a/mediamtx.yml
+++ b/mediamtx.yml
@@ -440,6 +440,11 @@ webrtcTrackGatherTimeout: 2s
 srt: true
 # Address of the SRT listener.
 srtAddress: :8890
+# SRT latency for all connections.
+# This configures both the receiver latency and peer latency of the SRT server.
+# Increasing latency helps handle packet loss over jittery networks but introduces playback lag.
+srtLatency: 120ms
+
 
 ###############################################
 # Default path settings
