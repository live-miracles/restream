From: Live Miracles <noreply@livemiracles.com>
Date: Mon, 16 Jun 2026 00:00:00 +0530
Subject: [PATCH] feat(srt): apply udpReadBufferSize to SRT socket via reflection

DESCRIPTION:
  This patch enables the global 'udpReadBufferSize' configuration option
  (from mediamtx.yml) to be applied directly to the underlying SRT server
  UDP socket's kernel receive buffer (SO_RCVBUF).

  In gosrt v0.10.0 the listener struct holds the UDP socket as an
  unexported *net.UDPConn field named 'pc'. This patch uses reflection
  and unsafe.Pointer to extract it after srt.Listen() returns, then
  calls SetReadBuffer.

SYSTEM-LEVEL PREREQUISITES (sysctl):
  Linux caps SO_RCVBUF at net.core.rmem_max (typically 212 KB).
  To allow 25 MB:
    echo "net.core.rmem_max = 26214400" | sudo tee /etc/sysctl.d/99-mediamtx-srt.conf
    sudo sysctl --system

VERIFIED:
  ss -u -a -m | grep 8890 shows rb52428800 (kernel doubles the request).
  Log: "[SRT] UDP kernel read buffer set to 26214400 bytes"

---
diff --git a/internal/core/core.go b/internal/core/core.go
index 5823464..fc21179 100644
--- a/internal/core/core.go
+++ b/internal/core/core.go
@@ -662,6 +662,7 @@ func (p *Core) createResources(initial bool) error {
 			ReadTimeout:         p.conf.ReadTimeout,
 			WriteTimeout:        p.conf.WriteTimeout,
 			UDPMaxPayloadSize:   p.conf.UDPMaxPayloadSize,
+			UDPReadBufferSize:   p.conf.UDPReadBufferSize,
 			RunOnConnect:        p.conf.RunOnConnect,
 			RunOnConnectRestart: p.conf.RunOnConnectRestart,
 			RunOnDisconnect:     p.conf.RunOnDisconnect,
diff --git a/internal/servers/srt/server.go b/internal/servers/srt/server.go
index f69a0ad..3d9947e 100644
--- a/internal/servers/srt/server.go
+++ b/internal/servers/srt/server.go
@@ -5,10 +5,12 @@ import (
 	"context"
 	"errors"
 	"fmt"
+	"net"
 	"reflect"
 	"sort"
 	"sync"
 	"time"
+	"unsafe"

 	srt "github.com/datarhei/gosrt"
 	"github.com/google/uuid"
@@ -79,6 +81,7 @@ type Server struct {
 	ReadTimeout         conf.Duration
 	WriteTimeout        conf.Duration
 	UDPMaxPayloadSize   int
+	UDPReadBufferSize   uint
 	RunOnConnect        string
 	RunOnConnectRestart bool
 	RunOnDisconnect     string
@@ -115,6 +118,10 @@ func (s *Server) Initialize() error {
 		return err
 	}

+	if s.UDPReadBufferSize > 0 {
+		s.applySocketReadBuffer()
+	}
+
 	s.ctx, s.ctxCancel = context.WithCancel(context.Background())

 	s.conns = make(map[*conn]struct{})
@@ -321,3 +328,28 @@ func (s *Server) APIConnsKick(uuid uuid.UUID) error {
 		return fmt.Errorf("terminated")
 	}
 }
+
+// applySocketReadBuffer extracts the underlying *net.UDPConn from the gosrt
+// listener (unexported field 'pc') and sets the kernel read buffer via SetReadBuffer.
+func (s *Server) applySocketReadBuffer() {
+	defer func() {
+		if r := recover(); r != nil {
+			s.Log(logger.Warn, "failed to apply UDP kernel read buffer via reflection: %v", r)
+		}
+	}()
+
+	// gosrt v0.10.0: listener.pc is *net.UDPConn (unexported)
+	val := reflect.ValueOf(s.ln).Elem()
+	pcField := val.FieldByName("pc")
+	if !pcField.IsValid() || pcField.IsNil() {
+		s.Log(logger.Warn, "SRT listener has no 'pc' field; cannot set UDP kernel read buffer")
+		return
+	}
+
+	udpConn := (*net.UDPConn)(unsafe.Pointer(pcField.Pointer()))
+	if err := udpConn.SetReadBuffer(int(s.UDPReadBufferSize)); err != nil {
+		s.Log(logger.Warn, "failed to set UDP kernel read buffer to %d bytes: %v", s.UDPReadBufferSize, err)
+	} else {
+		s.Log(logger.Info, "UDP kernel read buffer set to %d bytes", s.UDPReadBufferSize)
+	}
+}
